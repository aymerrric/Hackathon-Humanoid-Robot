# --- LLM (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
# Model to drive the agent. Opus 4.8 is the most capable; use claude-sonnet-4-6
# for cheaper/faster runs.
LLM_MODEL=claude-opus-4-8

# --- Ultra X2 robot ---
ULTRA_X2_HOST=192.168.1.10
ULTRA_X2_PORT=8080
# ULTRA_X2_API_KEY=...        # if the vendor SDK needs auth

# --- Safety ---
# When true, no command reaches the hardware — actions are simulated/logged.
DRY_RUN=true
# When true, every physical action waits for human approval before executing.
REQUIRE_CONFIRMATION=true
